generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model AppSettings {
  id                   Int      @id @default(1)
  companyName          String   @default("Open Agency Studio")
  companyEmail         String   @default("finance@openagency.test")
  defaultCurrency      String   @default("IDR")
  invoicePrefix        String   @default("INV")
  quotationPrefix      String   @default("QUO")
  paymentTermsDays     Int      @default(14)
  taxRate              Decimal  @default(11) @db.Decimal(5, 2)
  requiresApproval     Boolean  @default(true)
  paymentBankName      String?
  paymentAccountName   String?
  paymentAccountNumber String?
  paymentQrisUrl       String?
  whatsappProvider     WhatsAppProvider @default(EMULATOR)
  whatsappBridgeUrl    String?
  whatsappApiKey       String?
  whatsappSessionName  String?
  whatsappCountryCode  String   @default("62")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model DocumentSequence {
  id        Int                  @id @default(autoincrement())
  scopeKey  String
  type      DocumentSequenceType
  year      Int
  lastValue Int                  @default(0)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([scopeKey, type, year])
  @@index([type, year])
}

enum DocumentSequenceType {
  QUOTATION
  INVOICE
}

// ─── Existing: Product Catalog (unchanged) ───────────────────────────

model Category {
  id          Int       @id @default(autoincrement())
  organizationId String?
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([organizationId, createdAt])
}

model Product {
  id           Int         @id @default(autoincrement())
  organizationId String?
  name         String
  description  String
  type         ProductType @default(PRODUCT)
  isDigital    Boolean     @default(false)
  deliveryUrl  String?
  price        Decimal     @db.Decimal(10, 2)
  unit         String      @default("item") // item, hour, project, month, etc.
  photoUrl     String?
  categorySlug String
  category     Category    @relation(fields: [categorySlug], references: [slug], onDelete: Restrict, onUpdate: Cascade)
  quotationItems QuotationItem[]
  subscriptionPlans SubscriptionPlan[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([categorySlug])
  @@index([organizationId, type, createdAt])
}

enum ProductType {
  PRODUCT
  SERVICE
}

// ─── CRM ────────────────────────────────────────────────────────────

model Client {
  id         Int          @id @default(autoincrement())
  organizationId String?
  name       String
  email      String       @unique
  phone      String?
  company    String?
  address    String?
  status     ClientStatus @default(LEAD)
  notes      String?
  quotations Quotation[]
  projects   Project[]
  invoices   Invoice[]
  subscriptions ClientSubscription[]
  conversations Conversation[]
  messages   MessageLog[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([status, updatedAt])
  @@index([organizationId, status, updatedAt])
  @@index([phone])
}

enum ClientStatus {
  LEAD
  ACTIVE
  INACTIVE
  ARCHIVED
}

// ─── Quotations ─────────────────────────────────────────────────────

model Quotation {
  id         Int             @id @default(autoincrement())
  organizationId String?
  number     String          @unique
  clientId   Int
  client     Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  status     QuotationStatus @default(DRAFT)
  subtotal   Decimal         @default(0) @db.Decimal(15, 2)
  tax        Decimal         @default(0) @db.Decimal(15, 2)
  discount   Decimal         @default(0) @db.Decimal(15, 2)
  total      Decimal         @default(0) @db.Decimal(15, 2)
  validUntil DateTime?
  notes      String?
  items      QuotationItem[]
  project    Project?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([clientId])
  @@index([clientId, status, createdAt])
  @@index([organizationId, status, createdAt])
}

model QuotationItem {
  id          Int       @id @default(autoincrement())
  quotationId Int
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId   Int?
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  description String
  qty         Decimal   @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal   @db.Decimal(15, 2)
  amount      Decimal   @db.Decimal(15, 2)
  createdAt   DateTime  @default(now())

  @@index([quotationId])
}

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
}

// ─── Projects ───────────────────────────────────────────────────────

model Project {
  id          Int           @id @default(autoincrement())
  organizationId String?
  name        String
  clientId    Int
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  quotationId Int?          @unique
  quotation   Quotation?    @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  endDate     DateTime?
  budget      Decimal?      @db.Decimal(15, 2)
  notes       String?
  invoices    Invoice[]
  expenses    Expense[]
  subscriptions ClientSubscription[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([clientId])
  @@index([clientId, status, updatedAt])
  @@index([organizationId, status, updatedAt])
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

// ─── Finance ────────────────────────────────────────────────────────

model Invoice {
  id        Int           @id @default(autoincrement())
  organizationId String?
  number    String        @unique
  clientId  Int
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectId Int?
  project   Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  subscriptionId Int?
  subscription ClientSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  status    InvoiceStatus @default(DRAFT)
  subtotal  Decimal       @default(0) @db.Decimal(15, 2)
  tax       Decimal       @default(0) @db.Decimal(15, 2)
  total     Decimal       @default(0) @db.Decimal(15, 2)
  dueDate   DateTime?
  paidAt    DateTime?
  notes     String?
  payments  Payment[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([subscriptionId])
  @@index([clientId, status, createdAt])
  @@index([clientId, dueDate])
  @@index([subscriptionId, dueDate])
  @@index([organizationId, status, createdAt])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

model Payment {
  id        Int      @id @default(autoincrement())
  organizationId String?
  invoiceId Int
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(15, 2)
  method    String?  // transfer, cash, qris, credit
  reference String?
  paidAt    DateTime
  notes     String?
  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([invoiceId, paidAt])
  @@index([organizationId, paidAt])
}

model Expense {
  id          Int      @id @default(autoincrement())
  organizationId String?
  projectId   Int?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  category    String   // vendor, freelancer, tools, operational
  vendor      String?
  description String
  amount      Decimal  @db.Decimal(15, 2)
  date        DateTime
  receiptUrl  String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([projectId, date])
  @@index([organizationId, date])
}

model Conversation {
  id                Int                 @id @default(autoincrement())
  organizationId    String?
  channel           CommunicationChannel @default(WHATSAPP)
  phone             String
  displayName       String?
  clientId          Int?
  client            Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  externalThreadId  String?
  status            ConversationStatus  @default(OPEN)
  lastMessagePreview String?
  lastMessageAt     DateTime?
  unreadCount       Int                 @default(0)
  messages          MessageLog[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([channel, phone])
  @@index([clientId])
  @@index([organizationId, status, lastMessageAt])
}

model MessageLog {
  id               Int                  @id @default(autoincrement())
  organizationId   String?
  conversationId   Int
  conversation     Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  clientId         Int?
  client           Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  channel          CommunicationChannel @default(WHATSAPP)
  direction        MessageDirection
  status           MessageStatus        @default(PENDING)
  provider         WhatsAppProvider?
  externalMessageId String?
  body             String
  attachmentUrl    String?
  attachmentName   String?
  documentUrl      String?
  metadata         Json?
  sentAt           DateTime?
  createdAt        DateTime             @default(now())

  @@index([conversationId, createdAt])
  @@index([clientId, createdAt])
  @@index([organizationId, createdAt])
}

model SubscriptionPlan {
  id            Int                  @id @default(autoincrement())
  organizationId String?
  name          String
  slug          String               @unique
  description   String?
  serviceId     Int?
  service       Product?             @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  price         Decimal              @db.Decimal(15, 2)
  interval      SubscriptionInterval @default(MONTHLY)
  isActive      Boolean              @default(true)
  subscriptions ClientSubscription[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([serviceId])
  @@index([serviceId, isActive])
  @@index([organizationId, isActive, createdAt])
}

model ClientSubscription {
  id              Int                @id @default(autoincrement())
  organizationId  String?
  clientId        Int
  client          Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planId          Int
  plan            SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)
  projectId       Int?
  project         Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime
  nextBillingDate DateTime?
  endDate         DateTime?
  autoRenew       Boolean            @default(true)
  priceOverride   Decimal?           @db.Decimal(15, 2)
  notes           String?
  invoices        Invoice[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([clientId])
  @@index([planId])
  @@index([projectId])
  @@index([clientId, status, createdAt])
  @@index([status, nextBillingDate])
  @@index([organizationId, status, nextBillingDate])
}

enum SubscriptionInterval {
  ONE_TIME
  LIFETIME
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum CommunicationChannel {
  WHATSAPP
}

enum ConversationStatus {
  OPEN
  ARCHIVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  RECEIVED
  SENT
  DELIVERED
  READ
  FAILED
}

enum WhatsAppProvider {
  EMULATOR
  BRIDGE
}
